    "class-validator": "^0.14.1",
    "clawhub": "^0.9.0",
    "express": "^5.0.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "langchain": "^0.3.0",
    "langsmith": "^0.5.12",
    "ms": "^2.1.3",
    "nodemailer": "^9.0.3",
    "openai": "^4.77.0",
    "openclaw": "^2026.3.13",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
