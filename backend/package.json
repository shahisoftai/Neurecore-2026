{
  "name": "backend",
  "version": "0.0.1",
  "description": "<p align=\"center\">\r   <a href=\"http://nestjs.com/\" target=\"blank\"><img src=\"https://nestjs.com/img/logo-small.svg\" width=\"120\" alt=\"Nest Logo\" /></a>\r </p>",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "start:local-prod": "NODE_ENV=production pnpm run build && pnpm run start:prod",
    "vercel-build": "pnpm prisma generate && pnpm run build",
    "postinstall": "pnpm prisma generate || true",
    "prisma:generate": "prisma generate",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config jest.config.js",
    "test:legacy": "jest --config jest.config.js test/unit/analytics.service.spec.ts test/unit/connectors.service.spec.ts test/unit/cookie-auth.service.spec.ts test/unit/hermes-context.service.spec.ts test/unit/hermes-router-node.spec.ts test/unit/hermes-runtime.service.spec.ts test/unit/token.service.spec.ts",
    "test:watch": "jest --config jest.config.js --watch",
    "test:cov": "jest --config jest.config.js --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config jest.config.js --runInBand",
    "test:e2e": "jest --config test/jest-e2e.json",
    "test:unit": "jest --config jest.config.js --testPathPatterns=\"\\.spec\\.ts$\"",
    "test:integration": "jest --config jest.config.js --testPathPatterns=\"\\.integration-spec\\.ts$\"",
    "test:staged": "jest --config jest.config.js --staged",
    "test:ci": "jest --config jest.config.js --ci --coverage --reporters=default --reporters=jest-junit",
    "seed:templates": "node prisma/seed-platform-templates.cjs",
    "seed:admin": "node scripts/make-superadmin.cjs",
    "seed:composition": "node prisma/seed-business-composition.cjs",
    "seed:question-packs": "node prisma/seed-question-packs.cjs",
    "seed:project-types": "node prisma/seed-project-types.cjs",
    "seed:question-packs:check": "node prisma/seed-question-packs.cjs --check",
    "seed:project-types:check": "node prisma/seed-project-types.cjs --check",
    "seed:onboarding-allocator": "node prisma/seed-onboarding-allocator.cjs",
    "brevo:bootstrap": "node scripts/brevo-bootstrap-tenant.cjs",
    "test:seed:question-packs": "node scripts/test-seed-idempotency.mjs question-packs",
    "test:seed:project-types": "node scripts/test-seed-idempotency.mjs project-types",
    "test:industries-sync": "node scripts/check-industries-sync.mjs"
  },
  "dependencies": {
    "@langchain/core": "^1.1.16",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^1.1.16",
    "@nestjs/common": "^11.0.1",
