// ─── Business Composition: Six Pools (Phase 10) ─────────────────────────
// Refactor of `templates` into six orthogonal pools that compose a Package.
// Each pool owns one Prisma model and one CRUD surface. See
// memory-bank-new/plans/admin-business-composition.md.

// ─── Enums ──────────────────────────────────────────────────────────────

enum IndustryStatus {
  ACTIVE
  ARCHIVED

  @@map("industry_status")
}

enum TierTemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("tier_template_status")
}

enum FeatureCategory {
  INTEGRATION
  API
  COMMUNICATION
  BRANDING
  ANALYTICS
  AUTOMATION
  SECURITY
  PLATFORM

  @@map("feature_category")
}

enum PackageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("package_status")
}

enum PackageScope {
  FUNCTIONAL
  VERTICAL
  HYBRID

  @@map("package_scope")
}

// ─── Pool #3: Industries ─────────────────────────────────────────────────

model Industry {
  id          String         @id @default(uuid())
  slug        String         @unique
  name        String
  description String?        @db.Text
  icon        String?
  status      IndustryStatus @default(ACTIVE)
  sortOrder   Int            @default(0)

  packages Package[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
  @@map("industries")
}

// ─── Pool #4: Tier Templates (commercial offering) ───────────────────────
// Distinct from the billing `Tier` model. A TierTemplate represents a
// commercial offering (Starter / Professional / Enterprise / Government)
// and may map to one or more billing `Tier` rows.

model TierTemplate {
  id          String             @id @default(uuid())
  slug        String             @unique
  name        String
  tagline     String?
  description String?            @db.Text
  status      TierTemplateStatus @default(DRAFT)
  sortOrder   Int                @default(0)

  defaultBillingTierId String?
  defaultBillingTier   Tier?   @relation(fields: [defaultBillingTierId], references: [id], onDelete: SetNull)

  packages Package[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
  @@map("tier_templates")
}

// ─── Pool #5: Features ───────────────────────────────────────────────────

model Feature {
  id             String          @id @default(uuid())
  key            String          @unique
  name           String
  description    String?         @db.Text
  category       FeatureCategory
  icon           String?
  integrationKey String?
  sortOrder      Int             @default(0)

  packages Package[] @relation("PackageFeatures")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, sortOrder])
  @@map("features")
}

// ─── Pool #6: Packages (composite root) ──────────────────────────────────

model Package {
  id          String        @id @default(uuid())
  slug        String
  name        String
  description String?       @db.Text
  status      PackageStatus @default(DRAFT)
  sortOrder   Int           @default(0)

  // Catalogue meta — supports package reuse across industries/tiers
  scope   PackageScope @default(FUNCTIONAL)
  version Int          @default(1)

  industryId String
  industry   Industry @relation(fields: [industryId], references: [id], onDelete: Restrict)

  tierTemplateId String
  tierTemplate   TierTemplate @relation(fields: [tierTemplateId], references: [id], onDelete: Restrict)

  // M2M composition — pool entities only (no tenant-runtime rows)
  departments DepartmentTemplate[] @relation("PackageDepartments")
  aiAgents    AgentTemplate[]      @relation("PackageAgents")
  features    Feature[]            @relation("PackageFeatures")

  suggestedAgentCount      Int?
  suggestedDepartmentCount Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([industryId, tierTemplateId, slug])
  @@index([industryId, tierTemplateId])
  @@index([status])
  @@map("packages")
}

