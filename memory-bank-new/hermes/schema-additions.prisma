// ─── HermesAgent (live schema line 2513) ──────────────────────────────────────

model HermesAgent {
  id           String   @id @default(cuid())
  name         String
  type         HermesAgentType
  status       HermesAgentStatus @default(IDLE)
  description  String?
  model        String?

  systemPrompt String?  @db.Text
  config       Json     @default("{}")

  permissions  String[] @default([])
  allowedPaths String[] @default([])
  blockedPaths String[] @default([])
  maxFileSize  Int      @default(10485760)
  isActive     Boolean  @default(true)
  tenantId     String
  workspaceId   String?   // Reserved for future Workspace module (no Workspace model yet)

  capabilities HermesCapability[]
  toolPermissions HermesToolPermission[]
  memory       HermesMemoryEntry[]
  sessions     HermesSession[]
  auditLogs    HermesAuditLog[]

  agents       Agent[]  // Back-relation — live schema line 783 (Agent.hermesAgentId)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([type, tenantId])
  @@index([status, tenantId])
  @@index([workspaceId])
}

enum HermesAgentType {
  HR
  FINANCE
  SALES
  MARKETING
  LEGAL
  RESEARCH
  ENGINEERING
  QA
  SECURITY
  OPERATIONS
  CUSTOMER_SUPPORT
  CUSTOM
}

enum HermesAgentStatus {
  IDLE
  RUNNING
  SUSPENDED
}

// ─── HermesCapability (live schema line 2548) ─────────────────────────────────

model HermesCapability {
  id            String   @id @default(cuid())
  hermesAgentId String
  name          String
  description   String?
  inputSchema   Json?
  outputSchema  Json?
  costEstimate  Float?
  avgDuration   Int?
  usageCount    Int      @default(0)

  hermesAgent   HermesAgent @relation(fields: [hermesAgentId], references: [id], onDelete: Cascade)

  @@unique([hermesAgentId, name])
  @@index([hermesAgentId])
}

// ─── HermesToolPermission (live schema line 2565) ─────────────────────────────

model HermesToolPermission {
  id            String   @id @default(cuid())
  hermesAgentId String
  toolName      String
  permission    ToolPermissionLevel @default(DENY)
  conditions    Json?

  hermesAgent   HermesAgent @relation(fields: [hermesAgentId], references: [id], onDelete: Cascade)

  @@unique([hermesAgentId, toolName])
  @@index([hermesAgentId])
}

enum ToolPermissionLevel {
  ALLOW
  DENY
  READ_ONLY
  WRITE_ONLY
  APPROVAL_REQUIRED
}

// ─── HermesSession (live schema line 2578) ────────────────────────────────────
// NOTE: Live schema has 4 indexes; this file had 3. Added @@index([status, tenantId]).

model HermesSession {
  id            String   @id @default(cuid())
  hermesAgentId String
  userId        String
  tenantId      String
  workspaceId   String?
  threadId      String   @unique @default(cuid())
  status        SessionStatus @default(ACTIVE)
  context       Json     @default("{}")

  messages      HermesMessage[]

  hermesAgent   HermesAgent @relation(fields: [hermesAgentId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  expiresAt     DateTime?

  @@index([hermesAgentId, tenantId])
  @@index([userId, tenantId])
  @@index([threadId])
  @@index([status, tenantId])   // Added — matches live schema
}

enum SessionStatus {
  ACTIVE
  SUSPENDED
  COMPLETED
  EXPIRED
}

// ─── HermesMessage (live schema line 2602) ───────────────────────────────────

model HermesMessage {
  id           String   @id @default(cuid())
  sessionId    String
  role         MessageRole
  content      String   @db.Text
  metadata     Json?
  toolCalls    Json?
  toolResults  Json?
  error        String?
  createdAt    DateTime @default(now())

  session      HermesSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

enum MessageRole {
  USER
  HERMES
  SYSTEM
}

// ─── HermesMemoryEntry (live schema line 2618) ────────────────────────────────
// NOTE: Live schema is MISSING the Gist vector index. Apply via raw SQL:
//   CREATE INDEX "HermesMemoryEntry_embedding_idx"
//     ON "HermesMemoryEntry" USING Gist (embedding);
// (Prisma 5.22 does not support `type: Gist` on Float[] — requires @pgvector/prisma
