model HermesMemoryEntry {
  id            String   @id @default(cuid())
  hermesAgentId String
  tenantId      String
  workspaceId   String?
  type          HermesMemoryType
  content       String   @db.Text
  summary       String?  @db.Text
  embedding     Float[]
  importance    Float    @default(0.5)
  source        String?
  metadata      Json?
  expiresAt     DateTime?

  hermesAgent  HermesAgent @relation(fields: [hermesAgentId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([hermesAgentId, tenantId])
  @@index([hermesAgentId, type])
  @@index([tenantId])
  // Gist index applied via raw SQL — see header comment above
}

enum HermesMemoryType {
  PERSONAL
  EPISODIC
  PROCEDURAL
}

// ─── HermesAuditLog (live schema line 2642) ───────────────────────────────────

model HermesAuditLog {
  id             String   @id @default(cuid())
  hermesAgentId  String
  sessionId      String?
  taskId         String?
  tenantId       String
  workspaceId     String?
  action         String
  resource       String?
  resourceId     String?
  request        Json?
  response       Json?
  decision       String?
  reason         String?
  governanceRule String?
  durationMs     Int?
  costUsd        Float?
  tokensUsed     Int?
  createdAt      DateTime @default(now())

  hermesAgent    HermesAgent @relation(fields: [hermesAgentId], references: [id], onDelete: Cascade)

  @@index([hermesAgentId, tenantId])
  @@index([tenantId, createdAt])
  @@index([action, tenantId])
}

// ─── ApprovalWorkflow (live schema line 2669) ─────────────────────────────────

model ApprovalWorkflow {
  id            String   @id @default(cuid())
  name          String
  description   String?
  workflowType  ApprovalWorkflowType
  currentStep   Int      @default(0)
  status        ApprovalStatus @default(PENDING)
  context       Json     @default("{}")
  result        Json?
  requesterId   String
  tenantId      String
  workspaceId   String?
  routineRunId  String?

  steps         ApprovalWorkflowStep[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedAt   DateTime?

  @@index([tenantId])
  @@index([status, tenantId])
  @@index([requesterId, tenantId])
}

enum ApprovalWorkflowType {
  HIRE
  FIRE
  REFUND
  CONTRACT
  BUDGET
  VENDOR_PAYMENT
  DATA_ACCESS
  CUSTOM
}

model ApprovalWorkflowStep {
  id                  String   @id @default(cuid())
  approvalWorkflowId  String
  stepOrder           Int
  approverRole        UserRole[]
  approverId          String?
  status              ApprovalStatus @default(PENDING)
  decision            String?
  comment             String?
  decidedAt           DateTime?

  approvalWorkflow    ApprovalWorkflow @relation(fields: [approvalWorkflowId], references: [id], onDelete: Cascade)

  @@unique([approvalWorkflowId, stepOrder])
  @@index([approvalWorkflowId])
}

